#!/bin/bash
# 初回の権限セットアップ。マイクとアクセシビリティの許可ダイアログを出す。
# このウィンドウ（ターミナル.app）に対して許可が付与される。
cd "$(dirname "$0")" || exit 1
source .venv/bin/activate
clear
cat <<'MSG'
============================================================
   Groq Dictation  権限セットアップ
============================================================
 これから許可ダイアログを2つ出します。

   1) マイク       → 「許可 / OK」を押すだけ
   2) アクセシビリティ → 出てきた設定画面で「ターミナル」をオンに

 画面の指示に従ってください。
============================================================

MSG

echo "[1/2] マイクの許可ダイアログを出します ..."
python - <<'PY'
import sounddevice as sd, time
try:
    s = sd.InputStream(samplerate=16000, channels=1, dtype='float32')
    s.start(); time.sleep(1.5); s.stop(); s.close()
    print("    → ダイアログが出たら『許可』を押してください。")
except Exception as e:
    print("    マイク初期化メッセージ:", e)
PY
echo ""
sleep 1
echo "[2/2] アクセシビリティ（自動貼り付け・ホットキー用）の許可を求めます ..."
osascript -e 'tell application "System Events" to key code 123' 2>/dev/null
echo "    → 『システム設定を開く』が出たら開き、リストの『ターミナル』をオンに。"
echo "      （オンにするときに指紋認証 or パスワードを求められたら入力）"
echo ""
echo "============================================================"
echo " 2つ許可できたら、このウィンドウは閉じてOKです。"
echo " 次は『確認.command』をダブルクリックして動作テストします。"
echo "============================================================"
read -r -p "Enterで閉じます..." _
