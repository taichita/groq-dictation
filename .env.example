# Groq Dictation 設定見本。
# このファイルを「.env」という名前でコピーして、自分の値を入れてください。
# .env は .gitignore 済み（GitHub には上がりません）。

# 必須: https://console.groq.com/keys で発行した自分のキー（gsk_ で始まる）
GROQ_API_KEY=your_groq_api_key_here

# 録音開始/停止キー（既定: 右Ctrl + Alt。pynput 形式で変更可）
HOTKEY=<ctrl_r>+<alt>
# 音は鳴らさない（録音中は画面右下の赤い丸で状態を確認）
SOUND_CUE=false
# 録音中だけ画面右下に赤い丸を表示
OVERLAY_ICON=true

# 任意（未指定なら既定値が使われます）
# GROQ_MODEL=whisper-large-v3-turbo
# LANGUAGE=ja
# AUTO_PASTE=true
# MIN_RECORD_SEC=0.4
# MAX_RECORD_SEC=120
# REQUEST_TIMEOUT=60
# MAX_RETRIES=2
